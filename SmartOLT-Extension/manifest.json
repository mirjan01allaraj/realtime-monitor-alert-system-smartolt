{
  "manifest_version": 3,
  "name": "Multi Region Web Monitor",
  "version": "4.0",
  "description": "Monitor SmartOLT numbers, auto-save selectors, send alerts to backend.",

  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs",
    "alarms"
  ],

  "host_permissions": [
    "http://127.0.0.1:5005/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup.html",
    "default_title": "SmartOLT Monitor"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
